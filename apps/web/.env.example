# Public URL of the workers/decap-oauth Cloudflare Worker that brokers
# GitHub OAuth for the Decap CMS admin (public/admin). Not read by the CMS
# directly — scripts/generate-decap-config.mjs bakes it into
# public/admin/config.yml's `backend.base_url` at dev/build time.
#
# Before a custom domain exists, use the worker's *.workers.dev URL, e.g.:
#   NEXT_PUBLIC_DECAP_AUTH_BASE_URL=https://decap-oauth.<your-subdomain>.workers.dev
# After buying a domain and routing the worker to it, just update this value
# and rebuild/redeploy — no code changes needed.
NEXT_PUBLIC_DECAP_AUTH_BASE_URL=

# Shared HTTP Basic Auth credentials gating /admin (see middleware.ts), on
# top of Decap's own GitHub OAuth login. Not enforced on localhost. Set
# these as real Cloudflare secrets in production — never commit real values:
#   wrangler secret put CMS_BASIC_AUTH_USER
#   wrangler secret put CMS_BASIC_AUTH_PASSWORD
CMS_BASIC_AUTH_USER=
CMS_BASIC_AUTH_PASSWORD=
